---
const { title = "Report" } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <header style="padding: 16px; border-bottom: 1px solid #ddd;">
      <h1>{title}</h1>

      <nav>
        <a href="/report/ru">RU</a> |
        <a href="/report/en">EN</a>
      </nav>
    </header>

    <main style="padding: 16px;">
      <slot />
    </main>
  </body>
</html>